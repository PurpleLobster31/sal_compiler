@ Calculadora estatistica para uma sequencia de inteiros.
@ Cobre: globals, vetores, fn, proc, for, for com step,
@        loop while, loop until, if/else encadeado, match,
@        tipo bool, scan em vetor e chamadas aninhadas.

module Calculadora;

globals
    dados[20]: int;
    n: int;

@ Retorna o maior entre dois inteiros.
fn maximo(a: int, b: int): int
start
    if (a > b)
        ret a
    else
        ret b;
end

@ Retorna o menor entre dois inteiros.
fn minimo(a: int, b: int): int
start
    if (a < b)
        ret a
    else
        ret b;
end

@ Soma os primeiros qtd elementos do vetor global dados.
fn soma_vetor(qtd: int): int
locals
    i, total: int;
start
    total := 0;
    for i := 1 to qtd do
        total := total + dados[i];
    ret total;
end

@ Retorna o maior elemento em dados[1..qtd].
fn maior_vetor(qtd: int): int
locals
    i, maior: int;
start
    maior := dados[1];
    for i := 2 to qtd do
        maior := maximo(maior, dados[i]);
    ret maior;
end

@ Retorna o menor elemento em dados[1..qtd].
fn menor_vetor(qtd: int): int
locals
    i, menor: int;
start
    menor := dados[1];
    for i := 2 to qtd do
        menor := minimo(menor, dados[i]);
    ret menor;
end

@ Le n valores do teclado para o vetor global dados.
@ Usa loop..until para garantir ao menos uma iteracao.
proc ler_dados()
locals
    i: int;
start
    i := 1;
    loop
        print("  [", i, "]: ");
        scan(dados[i]);
        i := i + 1;
    until (i > n);
end

@ Imprime os elementos de indice par usando for com step 2.
proc imprimir_pares()
locals
    i: int;
    achou: bool;
start
    achou := false;
    print("Elementos de indice par:");
    for i := 2 to n step 2 do
        start
            print("  dados[", i, "] = ", dados[i]);
            achou := true;
        end;
    if (~achou)
        print("  (nenhum elemento de indice par)");
end

proc main()
locals
    s, maior, menor, media, amp, faixa: int;
    valido: bool;
start
    print("=== Calculadora de Sequencias ===");

    @ Valida o tamanho da entrada com loop while (pre-teste)
    valido := false;
    loop while (~valido)
        start
            print("Quantos valores analisar? (1 a 20): ");
            scan(n);
            if (n >= 1 ^ n <= 20)
                valido := true
            else
                print("Fora do intervalo! Informe entre 1 e 20.");
        end;

    @ Leitura dos dados via loop until (pos-teste)
    print("Digite os ", n, " valores:");
    ler_dados();

    @ Calculo dos resultados
    s     := soma_vetor(n);
    maior := maior_vetor(n);
    menor := menor_vetor(n);
    media := s / n;
    amp   := maior - menor;

    @ Exibicao dos resultados
    print("--- Resultados ---");
    print("Soma      : ", s);
    print("Maior     : ", maior);
    print("Menor     : ", menor);
    print("Media     : ", media);
    print("Amplitude : ", amp);

    @ Exibe elementos de indice par (demonstra for com step)
    imprimir_pares();

    @ Determina a faixa da media para classificacao via match
    if (media < 0)
        faixa := 1
    else if (media <= 9)
        faixa := 2
    else if (media <= 49)
        faixa := 3
    else if (media <= 99)
        faixa := 4
    else
        faixa := 5;

    print("--- Classificacao da media ---");
    match (faixa)
        when 1 => print("NEGATIVA");
        when 2 => print("MUITO BAIXA  (0 a 9)");
        when 3 => print("BAIXA        (10 a 49)");
        when 4 => print("MEDIA        (50 a 99)");
        when 5 => print("ALTA         (>= 100)");
        otherwise => print("INDEFINIDA");
    end;
end
